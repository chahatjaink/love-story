VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# Optional: Google Drive + Google Photos import (Picker + Photos Picker API)
# Cloud Console: enable "Google Picker API", "Google Drive API", "Photos Picker API".
# OAuth client: Web application. API key: restrict by HTTP referrer (your dev + prod URLs).
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
# Project number (Google Cloud home, or Firebase project settings)
VITE_GOOGLE_APP_ID=
